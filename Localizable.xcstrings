    "Du hast aktuell Caddy aktiv. Wenn du das Training-Abo kaufst, verlierst du deinen Caddy-Zugang. Mit Pro bekommst du beides – Training und Caddy – in einem Abo." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You currently have Caddy active. If you buy the Training subscription, you'll lose your Caddy access. With Pro you get both – Training and Caddy – in one subscription."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actualmente tienes Caddy activo. Si compras la suscripción Training, perderás el acceso a Caddy. Con Pro obtienes ambos – Training y Caddy – en una sola suscripción."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu as actuellement Caddy actif. Si tu achètes l'abonnement Training, tu perdras l'accès à Caddy. Avec Pro, tu obtiens les deux – Training et Caddy – dans un seul abonnement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al momento hai Caddy attivo. Se acquisti l'abbonamento Training, perderai l'accesso a Caddy. Con Pro ottieni entrambi – Training e Caddy – in un unico abbonamento."
          }
        }
      }
    },
